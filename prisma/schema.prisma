// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model StoreProfile {
  id             String    @id @default(cuid())
  businessName   String
  tagline        String?
  email          String?
  phone          String?
  instagramUrl   String?
  tiktokUrl      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum AdminRole {
  OWNER
  ADMIN
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  role      AdminRole @default(OWNER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Customer {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  email          String    @unique
  phone          String?
  orders         Order[]
  customRequests CustomRequest[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  SOLD_OUT
}

enum ProductCategory {
  BAG
  TOP
  DRESS
  SET
  CUSTOM
}

model Product {
  id            String          @id @default(cuid())
  title         String
  description   String
  price         Decimal         @db.Decimal(10, 2)
  category      ProductCategory
  status        ProductStatus   @default(DRAFT)
  isCustom      Boolean         @default(false)
  thumbnailUrl  String?
  images        ProductImage[]
  inventoryItem InventoryItem?
  orderItems    OrderItem[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ProductImage {
  id           String          @id @default(cuid())
  productId    String
  imageUrl     String
  altText      String?
  displayOrder Int             @default(0)
  createdAt    DateTime        @default(now())
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOC
  OUT_OF_STOCK
}

model InventoryItem {
  id                String          @id @default(cuid())
  productId         String          @unique
  sku               String?         @unique
  quantityOnHand    Int             @default(0)
  lowStockThreshold Int             @default(1)
  status            InventoryStatus @default(OUT_OF_STOCK)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  adjustments       InventoryAdjustment[]
}

enum InventoryAdjustmentReason {
  INITIAL_STOCK
  RESTOCK
  ORDER_PLACED
  CORRECTION
  DAMAGED
  RETURNED
}

model InventoryAdjustment {
  id              String                    @id @default(cuid())
  inventoryItemId String
  changeAmount    Int
  reason          InventoryAdjustmentReason
  note            String?
  createdAt       DateTime                  @default(now())

  inventoryItem   InventoryItem             @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id         String      @id @default(cuid())
  customerId String
  status     OrderStatus @default(PENDING)
  subtotal   Decimal     @db.Decimal(10, 2)
  shipping   Decimal     @default(0) @db.Decimal(10, 2)
  tax        Decimal     @default(0) @db.Decimal(10, 2)
  total      Decimal     @db.Decimal(10, 2)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items      OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  lineTotal Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

enum CustomRequestStatus {
  PENDING_REVIEW
  ACCEPTED
  DECLINED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model CustomRequest {
  id                String              @id @default(cuid())
  customerId        String
  status            CustomRequestStatus @default(PENDING_REVIEW)
  itemType          String
  description       String
  referenceImageUrl String?
  deadline          DateTime?
  quotedPrice       Decimal?            @db.Decimal(10, 2)
  adminNotes        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  measurements      Measurement?
}

model Measurement {
  id              String        @id @default(cuid())
  customRequestId String        @unique
  bust            Decimal?      @db.Decimal(5, 2)
  waist           Decimal?      @db.Decimal(5, 2)
  hips            Decimal?      @db.Decimal(5, 2)
  length          Decimal?      @db.Decimal(5, 2)
  shoulder        Decimal?      @db.Decimal(5, 2)
  inseam          Decimal?      @db.Decimal(5, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customRequest   CustomRequest @relation(fields: [customRequestId], references: [id], onDelete: Cascade)
}
